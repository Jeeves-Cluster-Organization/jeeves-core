# Telegram Homelab Capability Configuration Example
# Copy this file to .env and fill in your values

# =============================================================================
# TELEGRAM CONFIGURATION
# =============================================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Comma-separated list of Telegram user IDs allowed to use the bot
# Get your user ID by messaging @userinfobot on Telegram
TELEGRAM_ADMIN_USER_IDS=123456789,987654321

# Optional: Webhook URL if using webhooks instead of polling
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook

# Maximum message length (Telegram limit is 4096)
TELEGRAM_MAX_MESSAGE_LENGTH=4096

# Polling timeout in seconds
TELEGRAM_POLLING_TIMEOUT=30

# =============================================================================
# SSH CONFIGURATION
# =============================================================================
# JSON array of allowed SSH hosts (hostname:port)
SSH_HOSTS=["homelab.local:22", "server1.local:22", "server2.local:22"]

# Path to SSH private key for authentication
SSH_PRIVATE_KEY_PATH=/home/user/.ssh/id_rsa

# Path to SSH known_hosts file
SSH_KNOWN_HOSTS_PATH=/home/user/.ssh/known_hosts

# Default SSH user
SSH_DEFAULT_USER=root

# SSH command timeout in seconds
SSH_TIMEOUT_SECONDS=30

# Maximum output characters from SSH commands
SSH_MAX_OUTPUT_CHARS=8000

# Strict host key checking (true/false)
SSH_STRICT_HOST_KEY_CHECKING=true

# =============================================================================
# FILE SYSTEM CONFIGURATION
# =============================================================================
# Base path for homelab files
HOMELAB_BASE_PATH=/home/homelab

# JSON array of allowed directories for file access
HOMELAB_ALLOWED_DIRS=["/home/homelab/scripts", "/home/homelab/configs", "/home/homelab/docs"]

# Maximum file size to read (in KB)
HOMELAB_FILE_READ_LIMIT_KB=500

# Maximum search results
HOMELAB_SEARCH_MAX_RESULTS=50

# Maximum directory listing depth
HOMELAB_MAX_FILE_LISTING_DEPTH=3

# =============================================================================
# CALENDAR CONFIGURATION
# =============================================================================
# Calendar backend type: ics, caldav, or google
CALENDAR_API_TYPE=ics

# ICS calendar URL (if using ICS backend)
CALENDAR_URL=http://calendar.local/user.ics

# CalDAV configuration (if using CalDAV backend)
# CALDAV_URL=https://caldav.example.com/calendars/user/
# CALDAV_USERNAME=username
# CALDAV_PASSWORD=password

# Google Calendar configuration (if using Google backend)
# GOOGLE_CALENDAR_CREDENTIALS_PATH=/path/to/credentials.json

# Maximum events per query
CALENDAR_MAX_EVENTS_PER_QUERY=50

# Default days ahead for calendar queries
CALENDAR_DEFAULT_DAYS_AHEAD=7

# =============================================================================
# NOTES CONFIGURATION
# =============================================================================
# Notes backend: filesystem, sqlite, or postgresql
NOTES_BACKEND=filesystem

# Path to notes directory (if using filesystem backend)
NOTES_PATH=/home/homelab/notes

# Maximum search results for notes
NOTES_SEARCH_MAX_RESULTS=20

# Maximum preview characters per note
NOTES_MAX_NOTE_PREVIEW_CHARS=500

# Supported note file extensions (comma-separated)
NOTES_SUPPORTED_EXTENSIONS=.md,.txt,.org

# Database URL (if using sqlite or postgresql backend)
# NOTES_DATABASE_URL=sqlite:///path/to/notes.db
# NOTES_DATABASE_URL=postgresql://user:pass@localhost/notes

# =============================================================================
# CAPABILITY SETTINGS
# =============================================================================
# Enable confirmation prompts for destructive operations
TELEGRAM_HOMELAB_ENABLE_CONFIRMATIONS=true

# Maximum concurrent requests
TELEGRAM_HOMELAB_MAX_CONCURRENT_REQUESTS=5
