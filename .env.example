# =============================================================================
# agent-core — environment variables
# =============================================================================

# --- LLM API keys (provider-specific; set whichever you use) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# --- Model selection ---
# Default model for the pi harness (overridden by .pi/settings.json).
# PI_MODEL=claude-sonnet-4-6

# Role aliases: any MODEL_* env var becomes a role name.
# Usage: set model: Some("fast") in a ChatRequest to get the aliased model.
# MODEL_FAST=gpt-4o-mini
# MODEL_REASONING=claude-sonnet-4-6

# --- Custom endpoint (vLLM, llama.cpp, any OpenAI-compatible server) ---
# If set, every model is routed through the OpenAI adapter to this URL.
# LLM_API_BASE=http://localhost:8080/v1

# --- Observability ---
# RUST_LOG=info
# AGENT_LOG_FORMAT=text          # text | json
