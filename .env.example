# =============================================================================
# Jeeves Core — Environment Variables
# Copy to .env and edit for your deployment
# =============================================================================

# --- Kernel IPC ---
AIRFRAME_KERNEL_ADDRESS=127.0.0.1:50051

# --- LLM Configuration (required) ---
AIRFRAME_LLM_ADAPTER=openai_http     # openai_http | litellm | mock
AIRFRAME_LLM_BASE_URL=http://localhost:8080/v1
AIRFRAME_LLM_MODEL=llama-3.1-8b
AIRFRAME_LLM_API_KEY=               # optional for local servers

# --- Pipeline Bounds ---
CORE_MAX_ITERATIONS=3
CORE_MAX_LLM_CALLS=10
CORE_MAX_AGENT_HOPS=21
CORE_MAX_INPUT_TOKENS=4096
CORE_MAX_OUTPUT_TOKENS=2048
CORE_MAX_CONTEXT_TOKENS=16384
CORE_RESERVED_TOKENS=512
ORCH_MAX_CONCURRENT_AGENTS=4

# --- Feature Flags (prefix: FEATURE_) ---
FEATURE_USE_REDIS_STATE=false
FEATURE_ENABLE_DISTRIBUTED_MODE=false
FEATURE_ENABLE_TRACING=false
FEATURE_ENABLE_DEBUG_LOGGING=false

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Redis (when FEATURE_USE_REDIS_STATE=true) ---
REDIS_URL=redis://localhost:6379

# --- Observability ---
LOG_LEVEL=INFO
RUST_LOG=info
JEEVES_LOG_FORMAT=text              # text | json

# --- LLM Timeouts ---
AIRFRAME_LLM_TIMEOUT=300
AIRFRAME_LLM_MAX_RETRIES=3
