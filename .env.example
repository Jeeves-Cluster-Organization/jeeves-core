# =============================================================================
# Jeeves Core — Environment Variables
# Copy to .env and edit for your deployment
# =============================================================================

# --- LLM Configuration ---
LLM_API_KEY=                         # required for real LLM calls
LLM_MODEL=gpt-4o-mini               # default model name
LLM_BASE_URL=                        # OpenAI-compatible base URL (optional)

# --- MCP Server (tool aggregation) ---
# JEEVES_MCP_SERVERS='[{"name":"fs","transport":"stdio","command":"npx","args":["-y","@anthropic-ai/mcp-filesystem"]}]'

# --- Pipeline Bounds ---
CORE_MAX_ITERATIONS=20
CORE_MAX_LLM_CALLS=100
CORE_MAX_AGENT_HOPS=10

# --- Rate Limiting ---
CORE_RATE_LIMIT_RPM=60              # requests per minute per user
CORE_RATE_LIMIT_RPH=1000            # requests per hour per user
CORE_RATE_LIMIT_BURST=10            # burst size (per 10s window)

# --- Background Cleanup ---
CORE_CLEANUP_INTERVAL=300            # seconds between cleanup cycles
CORE_SESSION_RETENTION=3600          # seconds to keep stale sessions

# --- Observability ---
RUST_LOG=info
JEEVES_LOG_FORMAT=text              # text | json
OTEL_EXPORTER_OTLP_ENDPOINT=        # optional: OpenTelemetry OTLP endpoint
